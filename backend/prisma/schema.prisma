generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Product {
  id       Int    @id @default(autoincrement())
  title    String
  price    Int
  category String
  brand    String
  image    String
}
model Order {
  id        Int      @id @default(autoincrement())
  productId Int
  userId    String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}